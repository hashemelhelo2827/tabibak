# Turso Database (cloud SQLite)
TURSO_DB_URL=libsql://tabibak-username.turso.io
TURSO_DB_TOKEN=your-turso-token-here

# Server
PORT=3000
NODE_ENV=development

# JWT Secret (change in production!)
JWT_SECRET=your-256-bit-secret-change-me

# Frontend origin (for CORS - add your production URL)
FRONTEND_URL=http://localhost:3000

# Firebase Admin SDK (for FCM push notifications)
# Get these from Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----"

# Groq API Key (for Clinical Nutrition Advisor)
GROQ_API_KEY=your_groq_api_key_here

